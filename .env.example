# ============================================================
# XHS Study-Abroad Scraper — Environment Variables
# ============================================================
# Copy this file to .env (in the project root, next to xhs_scraper/)
# and fill in real values.  NEVER commit .env to version control.

# ------------------------------------------------------------
# Scraping behaviour
# ------------------------------------------------------------

# Set to "true" to use synthetic mock data (no real HTTP requests).
# Set to "false" to enable live scraping (requires XHS_COOKIE below).
USE_MOCK_DATA=true

# Your Xiaohongshu login cookie string.
# Obtain it by:
#   1. Open https://www.xiaohongshu.com in Chrome and log in.
#   2. Open DevTools → Network tab → reload the page.
#   3. Click any request to xiaohongshu.com → Headers → Request Headers → Cookie.
#   4. Copy the entire Cookie header value and paste it here.
# Required only when USE_MOCK_DATA=false.
XHS_COOKIE=

# Delay in seconds between keyword searches (default: 2.0).
# Increase this if you get rate-limited.
XHS_REQUEST_DELAY=2.0

# Maximum pages to scrape per keyword per run (default: 3, ~60 notes/keyword).
XHS_MAX_PAGES=3

# ------------------------------------------------------------
# Email — QQ Mail SMTP
# ------------------------------------------------------------

# Your QQ Mail address (e.g. 123456789@qq.com).
XHS_EMAIL_USER=your_qq_address@qq.com

# QQ Mail authorization token.
# Generate one at: QQ Mail → Settings → Account → POP3/IMAP/SMTP service → Generate authorization code.
# This is NOT your QQ login password.
XHS_EMAIL_PASSWORD=your_qq_mail_authorization_token

# Recipient address for daily reports.
EMAIL_RECIPIENT=1225265377@qq.com

# ------------------------------------------------------------
# Optional overrides (defaults shown)
# ------------------------------------------------------------

# SMTP host and port
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USE_SSL=false   # set to true to use port 465 with SSL instead of STARTTLS

# Minimum number of unique new users to aim for per day
# TARGET_USER_COUNT=50

# Minimum relevance score (0-100) to include a user in the report
# MIN_RELEVANCE_SCORE=20

# Daily schedule (24-hour, Asia/Shanghai timezone)
# SCHEDULE_HOUR=9
# SCHEDULE_MINUTE=0
